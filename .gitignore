#传统软抠图暗通道计算对比组
import cv2
import numpy as np
import matplotlib.pyplot as plt
import time
from scipy.sparse import lil_matrix, eye as sparse_eye
from scipy.sparse.linalg import spsolve
from skimage import img_as_float
from skimage.metrics import peak_signal_noise_ratio as psnr
from skimage.metrics import structural_similarity as ssim

# -------------------------- 中文显示 + 不显示窗口 --------------------------
plt.switch_backend('Agg')  # 关键：无GUI，计时精准
plt.rcParams['font.sans-serif'] = ['SimHei']
plt.rcParams['axes.unicode_minus'] = False


def dark_channel(im, size=15):
    min_channel = np.min(im, axis=2)
    kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (size, size))
    dark = cv2.erode(min_channel, kernel)
    return dark


def estimate_atmospheric_light(im, dark):
    h, w = dark.shape
    num_pixels = h * w
    num_top = max(int(num_pixels * 0.001), 1)
    dark_vec = dark.reshape(num_pixels)
    im_vec = im.reshape(num_pixels, 3)
    indices = np.argsort(dark_vec)[-num_top:]
    brightest = im_vec[indices]
    A = np.max(brightest, axis=0)
    return A


def estimate_transmission(im, A, omega=0.95, size=15):
    normed = im / A.reshape(1, 1, 3)
    transmission = 1 - omega * dark_channel(normed, size=size)
    return np.clip(transmission, 0, 1)


def _compute_laplacian_matrix(img, epsilon=1e-7, win_rad=1):
    img = img.astype(np.float64)
    h, w, c = img.shape
    n = h * w
    win_size = (2 * win_rad + 1) ** 2
    inds = np.arange(n).reshape(h, w)
    L = lil_matrix((n, n))

    for y in range(win_rad, h - win_rad):
        for x in range(win_rad, w - win_rad):
            win = img[y - win_rad:y + win_rad + 1, x - win_rad:x + win_rad + 1, :]
            win_inds = inds[y - win_rad:y + win_rad + 1, x - win_rad:x + win_rad + 1].reshape(-1)
            win_flat = win.reshape(-1, c)
            mu = np.mean(win_flat, axis=0, keepdims=True)
            cov = (win_flat - mu).T @ (win_flat - mu) / win_size
            cov += (epsilon / win_size) * np.eye(c)
            inv_cov = np.linalg.inv(cov)
            diff = win_flat - mu
            t = (1 + diff @ inv_cov @ diff.T) / win_size

            for i in range(win_size):
                for j in range(win_size):
                    L[win_inds[i], win_inds[j]] -= t[i, j]
            for i in range(win_size):
                L[win_inds[i], win_inds[i]] += 1
    return L.tocsr()


def soft_matting_refine(im, t, lambda_val=100, epsilon=1e-7, win_rad=1):
    h, w = t.shape
    n = h * w
    img = img_as_float(im)
    L = _compute_laplacian_matrix(img, epsilon=epsilon, win_rad=win_rad)
    t0 = t.reshape(-1)
    A_mat = L + lambda_val * lil_matrix(sparse_eye(n))
    b = lambda_val * t0
    refined = spsolve(A_mat.tocsr(), b)
    return np.clip(refined.reshape(h, w), 0, 1)


def recover_image(im, A, t, t0=0.1):
    t = np.maximum(t, t0)[:, :, np.newaxis]
    J = (im - A.reshape(1, 1, 3)) / t + A.reshape(1, 1, 3)
    return np.clip(J, 0, 1)


# ========================= 【新增】PSNR / SSIM 计算函数 =========================
def calculate_metrics(original, dehazed, gt):
    original = original.astype(np.float64)
    dehazed = dehazed.astype(np.float64)
    gt = gt.astype(np.float64)

    if gt.shape != original.shape:
        gt = cv2.resize(gt, (original.shape[1], original.shape[0]))

    psnr_hazy = psnr(gt, original, data_range=1.0)
    psnr_dehazed = psnr(gt, dehazed, data_range=1.0)

    ssim_hazy = ssim(gt, original, data_range=1.0, multichannel=True)
    ssim_dehazed = ssim(gt, dehazed, data_range=1.0, multichannel=True)

    print("\n===== 评价指标计算结果 =====")
    print(f"有雾图像 VS 参考图：")
    print(f"  PSNR = {psnr_hazy:.2f} dB    SSIM = {ssim_hazy:.4f}")
    print(f"去雾图像 VS 参考图：")
    print(f"  PSNR = {psnr_dehazed:.2f} dB    SSIM = {ssim_dehazed:.4f}")
    print("===========================\n")

    return psnr_hazy, ssim_hazy, psnr_dehazed, ssim_dehazed


def dehaze_soft_matting(input_path, output_path=None, dark_size=15, omega=0.95,
                        t0=0.1, lambda_val=100, epsilon=1e-7, win_rad=1):
    bgr = cv2.imread(input_path)
    if bgr is None:
        raise FileNotFoundError(f"Cannot read image: {input_path}")
    rgb = cv2.cvtColor(bgr, cv2.COLOR_BGR2RGB).astype(np.float64) / 255.0
    dark = dark_channel(rgb, size=dark_size)
    A = estimate_atmospheric_light(rgb, dark)
    t_coarse = estimate_transmission(rgb, A, omega=omega, size=dark_size)
    t_refined = soft_matting_refine(rgb, t_coarse, lambda_val=lambda_val,
                                    epsilon=epsilon, win_rad=win_rad)
    J = recover_image(rgb, A, t_refined, t0=t0)
    out_bgr = cv2.cvtColor((J * 255).astype(np.uint8), cv2.COLOR_RGB2BGR)
    if output_path is not None:
        cv2.imwrite(output_path, out_bgr)

    return {
        "original_rgb": rgb,
        "dehazed": J,
        "atmospheric_light": A,
        "dark_channel": dark,
        "transmission_coarse": t_coarse,
        "transmission_refined": t_refined
    }


if __name__ == "__main__":
    start_time = time.time()

    # ===================== 路径配置 =====================
    input_image = "input/hazy/hazy2.0.png"
    gt_image = "input/clear/GT2.0.png"  # 新增：清晰参考图
    output_image = "dehazed_soft_matting.jpg"

    # 去雾
    result = dehaze_soft_matting(input_image, output_image)

    # 读取参考图
    gt_bgr = cv2.imread(gt_image)
    gt_rgb = cv2.cvtColor(gt_bgr, cv2.COLOR_BGR2RGB) / 255.0

    # ===================== 计算指标 =====================
    calculate_metrics(result["original_rgb"], result["dehazed"], gt_rgb)
    # 1. 暗通道图
    plt.imsave("暗通道图.png", result["dark_channel"], cmap='gray')
    # 2. 粗透射率图
    plt.imsave("粗透射图.png", result["transmission_coarse"], cmap='gray')
    # 3. 精修透射率图（软抠图细化后）
    plt.imsave("精修透射图.png", result["transmission_refined"], cmap='gray')
    # 4. 去雾结果（RGB）
    plt.imsave("去雾结果.png", result["dehazed"])
    # 5. 大气光值可视化（色块）
    A = result["atmospheric_light"].reshape(1, 1, 3)
    A_img = np.tile(A, (50, 50, 1))
    plt.imsave("大气光色块.png", A_img)

    # ===================== 保存可视化（不弹窗） =====================
    plt.figure(figsize=(18, 8))
    plt.subplot(231), plt.imshow(result["original_rgb"]), plt.title("原始图像"), plt.axis("off")
    plt.subplot(232), plt.imshow(result["dark_channel"], cmap='gray'), plt.title("暗通道图"), plt.axis("off")
    plt.subplot(233), plt.imshow(result["transmission_coarse"], cmap='gray'), plt.title("粗透射图"), plt.axis("off")
    plt.subplot(234), plt.imshow(result["transmission_refined"], cmap='gray'), plt.title("精修透射图"), plt.axis("off")
    plt.subplot(235), plt.imshow(result["dehazed"]), plt.title("去雾结果"), plt.axis("off")

    A = result["atmospheric_light"].reshape(1, 1, 3)
    A_show = np.tile(A, (50, 50, 1))
    plt.subplot(236), plt.imshow(A_show), plt.title(
        f"大气光\nR:{A[0, 0, 0]:.2f} G:{A[0, 0, 1]:.2f} B:{A[0, 0, 2]:.2f}"), plt.axis("off")

    plt.tight_layout()
    plt.savefig("去雾可视化结果.png", bbox_inches='tight', dpi=200)
    plt.close()

    # ===================== 计时 =====================
    end_time = time.time()
    total_time = end_time - start_time

    print("-" * 50)
    print("Atmospheric Light A:", result["atmospheric_light"])
    print("Done. 去雾图已保存到:", output_image)
    print(f"✅ 总运行时间：{total_time:.2f} 秒 ({total_time * 1000:.0f} 毫秒)")
    print("-" * 50)
